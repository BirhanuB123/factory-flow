NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/factory_flow

# Required in production: random string, min 32 characters
JWT_SECRET=change-me-to-a-long-random-secret-in-production-min-32-chars
# Optional: after rotating JWT_SECRET, set old value here so existing tokens work until users re-login
# JWT_SECRET_PREVIOUS=
JWT_EXPIRES_IN=30d

# Logging: trace | debug | info | warn | error | silent
LOG_LEVEL=debug

# Rate limits (optional)
# RATE_LIMIT_AUTH_WINDOW_MINUTES=90
# RATE_LIMIT_LOGIN_MAX=30
# RATE_LIMIT_INVITE_COMPLETE_MAX=25
# RATE_LIMIT_API_WINDOW_MINUTES=1
# RATE_LIMIT_API_MAX=600
# RATE_LIMIT_PLATFORM_WINDOW_MINUTES=1
# RATE_LIMIT_PLATFORM_MAX=120

# Super-admin platform guardrails (optional)
# Comma-separated exact IPs (supports simple prefix wildcard like 10.0.*)
# SUPER_ADMIN_IP_ALLOWLIST=203.0.113.10,10.0.*
# Require x-step-up-password header for POST/PATCH/PUT/DELETE on /api/platform/*
# SUPER_ADMIN_STEP_UP_REQUIRED=false

# Trial lifecycle
# TRIAL_DEFAULT_DAYS=14
# TRIAL_AUTO_SUSPEND_ENABLED=true
# TRIAL_AUTO_SUSPEND_INTERVAL_MS=300000

# Billing webhook plan sync (public endpoint: POST /api/billing/webhook/sync)
# BILLING_WEBHOOK_SECRET=change-me
# Recommended replay protection for /api/billing/webhook/sync
# Signature base string: "{timestamp}.{raw_json_body}" (HMAC SHA-256 hex)
# Send headers: x-billing-webhook-timestamp (unix seconds), x-billing-webhook-signature (or x-webhook-signature)
# BILLING_WEBHOOK_HMAC_SECRET=change-me
# BILLING_WEBHOOK_TOLERANCE_SEC=300
# BILLING_WEBHOOK_IDEMPOTENCY_TTL_MS=86400000
# Optional comma-separated allowlist used to normalize billing plans
# BILLING_ALLOWED_PLANS=starter,pro,enterprise
# Stripe signed webhook endpoint (POST /api/billing/webhook/stripe)
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SECRET_KEY=sk_live_... (or sk_test_...)
# Optional Stripe price->plan mapping used when webhook sends stripePriceId:
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# Chapa self-serve subscription checkout
# CHAPA_SECRET_KEY=CHASECK_TEST-...
# Optional webhook guard for POST /api/billing/webhook/chapa
# CHAPA_WEBHOOK_SECRET=change-me
# Optional timestamped HMAC guard for Chapa callbacks (same signature base as above)
# Send headers: x-chapa-webhook-timestamp, x-chapa-webhook-signature
# CHAPA_WEBHOOK_HMAC_SECRET=change-me
# Optional override when Chapa should call your backend webhook
# CHAPA_WEBHOOK_CALLBACK_URL=https://api.yourdomain.com/api/billing/webhook/chapa
# Optional checkout currency and per-plan pricing (defaults: ETB + starter/pro/enterprise fallbacks)
# CHAPA_CURRENCY=ETB
# CHAPA_PLAN_STARTER_AMOUNT=1499
# CHAPA_PLAN_PRO_AMOUNT=3999
# CHAPA_PLAN_ENTERPRISE_AMOUNT=9999

# Behind reverse proxy (nginx) for correct client IP in rate limits
# TRUST_PROXY=true

# CORS: origin URL or * (default allows all in dev)
# CORS_ORIGIN=https://app.yourdomain.com

# Max JSON body size
# JSON_BODY_LIMIT=200kb

# Master data & manual stock audit trail (MongoDB collection auditlogs)
# AUDIT_LOG_ENABLED=true

# Order approval: discount % or order total triggers pending approval
# APPROVAL_DISCOUNT_PCT=5
# APPROVAL_ORDER_AMOUNT=50000

# Manager email digest + PO/invoice email (optional nodemailer)
# MANAGER_EMAILS=ops@example.com,cfo@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
