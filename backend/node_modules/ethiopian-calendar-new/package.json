{
  "name": "ethiopian-calendar-new",
  "version": "1.1.0",
  "description": "Convert between Ethiopian and Gregorian calendars easily. Provides accurate conversions between dates in the Ethiopian and Gregorian calendars.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ethiopian",
    "ethiopia-calender",
    "ethiopian-calender",
    "calendar",
    "date",
    "converter",
    "ethiopic",
    "Ethiopia",
    "Amharic",
    "calendar-converter"
  ],
  "author": "yared",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yaredabebe/ethiopian-calendar.git"
  },
 
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
