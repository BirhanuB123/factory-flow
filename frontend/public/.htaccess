# ─────────────────────────────────────────────────────────────
#  Factory Flow ERP — cPanel Apache Config
#  Subdomain: erp.gebetacloud.com  (Frontend only)
#  API is served from: api.erp.gebetacloud.com
# ─────────────────────────────────────────────────────────────

Options -MultiViews
RewriteEngine On

# ── React Router (SPA fallback) ───────────────────────────────
# Any request that is NOT a real file or directory falls back
# to index.html so React Router handles it client-side.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]
