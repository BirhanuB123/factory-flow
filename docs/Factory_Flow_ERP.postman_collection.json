{
  "info": {
    "name": "Factory Flow ERP API",
    "description": "Postman collection for the Factory Flow ERP backend. Set collection variables: baseUrl, token, tenantId, and resource IDs before running protected requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const tenantId = pm.collectionVariables.get('tenantId');",
          "if (tenantId) pm.request.headers.upsert({ key: 'x-tenant-id', value: tenantId });",
          "if (!pm.request.headers.get('Content-Type') && ['POST', 'PUT', 'PATCH'].includes(pm.request.method)) {",
          "  pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "tenantId", "value": "" },
    { "key": "id", "value": "" },
    { "key": "employeeId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "poId", "value": "" },
    { "key": "month", "value": "2026-06" },
    { "key": "tokenParam", "value": "" },
    { "key": "txRef", "value": "" },
    { "key": "barcode", "value": "" }
  ],
  "item": [
    {
      "name": "Public / Auth / Billing",
      "item": [
        { "name": "GET /api/health", "request": { "method": "GET", "url": "{{baseUrl}}/api/health" } },
        { "name": "GET /api/production/traveler/:token.html", "request": { "method": "GET", "url": "{{baseUrl}}/api/production/traveler/{{tokenParam}}.html" } },
        { "name": "POST /api/auth/login", "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/login", "body": { "mode": "raw", "raw": "{\n  \"identifier\": \"admin@example.com\",\n  \"password\": \"password123\"\n}" } } },
        { "name": "POST /api/auth/complete-invite", "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/complete-invite", "body": { "mode": "raw", "raw": "{\n  \"token\": \"\",\n  \"password\": \"\"\n}" } } },
        { "name": "PUT /api/auth/password", "request": { "method": "PUT", "url": "{{baseUrl}}/api/auth/password", "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"\",\n  \"newPassword\": \"\"\n}" } } },
        { "name": "GET /api/auth/me", "request": { "method": "GET", "url": "{{baseUrl}}/api/auth/me" } },
        { "name": "PATCH /api/auth/me", "request": { "method": "PATCH", "url": "{{baseUrl}}/api/auth/me", "body": { "mode": "raw", "raw": "{\n  \"name\": \"\"\n}" } } },
        { "name": "POST /api/auth/me/avatar", "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/me/avatar" } },
        { "name": "GET /api/auth/permissions", "request": { "method": "GET", "url": "{{baseUrl}}/api/auth/permissions" } },
        { "name": "POST /api/billing/webhook/stripe", "request": { "method": "POST", "url": "{{baseUrl}}/api/billing/webhook/stripe" } },
